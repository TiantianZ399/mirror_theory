{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":5,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/tiantian1zhang/mirror-x-continual-learning?scriptVersionId=336736545\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"id":"b9489003","cell_type":"markdown","source":"\n# Stress-testing “on-policy data mitigates forgetting” on a Kaggle GPU\n\nThis notebook runs a small, falsification-oriented continual-learning experiment.\n\nIt does **not** attempt to reproduce the full 7B-scale papers. Instead, it tests the causal rule under three controlled scenarios:\n\n1. **Supported / latent skill** — the new task is structurally close to an earlier task.\n2. **Novel mapping** — the target behavior is an arbitrary lookup table with little initial policy support.\n3. **Direct conflict** — the same inputs are assigned incompatible old and new labels.\n\nMethods:\n\n- **Offline SFT:** train on fixed expert demonstrations.\n- **Iterative on-policy SFT:** sample from the current policy, retain only verified-correct responses, and train on those self-generated trajectories.\n- **Mixed curriculum:** use expert SFT when on-policy coverage is low, then switch to iterative on-policy SFT.\n\nThe notebook reports the entire **target-gain / old-task-retention frontier**, rather than comparing methods only after equal numbers of updates.\n\n\n## Required Hugging Face authentication\n\nBefore running the notebook:\n\n1. Create a free Hugging Face **read** access token.\n2. In the Kaggle notebook, open **Add-ons → Secrets**.\n3. Add a secret named exactly `HF_TOKEN` and attach/enable it for this notebook.\n4. Keep Internet access enabled in the Kaggle notebook settings.\n\nThe token is read through `kaggle_secrets.UserSecretsClient`; it is never printed or saved in the notebook.\n\nRecommended Kaggle settings:\n\n- Accelerator: **GPU T4 x2**, **P100**, or better.\n- Internet: enabled for the first run so Hugging Face weights can be downloaded.\n- Default model: `Qwen/Qwen2.5-0.5B-Instruct`.\n- Expected runtime: roughly 45–120 minutes depending on GPU and chosen sweep.\n","metadata":{}},{"id":"4249e382","cell_type":"code","source":"!pip -q uninstall -y torchao\n!pip -q install -U \\\n    \"transformers>=4.48\" \\\n    \"datasets>=3.2\" \\\n    \"peft>=0.14\" \\\n    \"accelerate>=1.2\" \\\n    \"huggingface_hub>=0.28\" \\\n    sentencepiece\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:27:35.714209Z","iopub.execute_input":"2026-07-20T16:27:35.714523Z","iopub.status.idle":"2026-07-20T16:27:57.165714Z","shell.execute_reply.started":"2026-07-20T16:27:35.714488Z","shell.execute_reply":"2026-07-20T16:27:57.164588Z"}},"outputs":[{"name":"stdout","text":"\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m11.6/11.6 MB\u001b[0m \u001b[31m80.0 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m:00:01\u001b[0m:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m389.2/389.2 kB\u001b[0m \u001b[31m27.3 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m771.9/771.9 kB\u001b[0m \u001b[31m39.1 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m1.4/1.4 MB\u001b[0m \u001b[31m56.9 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m119.2/119.2 kB\u001b[0m \u001b[31m9.2 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m4.4/4.4 MB\u001b[0m \u001b[31m76.2 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m:00:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m516.0/516.0 kB\u001b[0m \u001b[31m30.4 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[?25h\u001b[31mERROR: pip's dependency resolver does not currently take into account all the packages that are installed. This behaviour is the source of the following dependency conflicts.\ngoogle-adk 1.29.0 requires google-cloud-bigquery-storage>=2.0.0, which is not installed.\u001b[0m\u001b[31m\n\u001b[0m","output_type":"stream"}],"execution_count":1},{"id":"3ea94152","cell_type":"code","source":"\nimport os, re, gc, json, math, random, shutil\nfrom dataclasses import dataclass, asdict\nfrom pathlib import Path\nfrom typing import Dict, List, Tuple\n\nimport numpy as np\nimport pandas as pd\nimport torch\nimport matplotlib.pyplot as plt\n\nfrom datasets import Dataset\nfrom transformers import (\n    AutoTokenizer,\n    AutoModelForCausalLM,\n    TrainingArguments,\n    Trainer,\n    set_seed,\n)\nfrom peft import LoraConfig, get_peft_model, PeftModel\n\nSEED = 42\nset_seed(SEED)\nrandom.seed(SEED)\nnp.random.seed(SEED)\n\nDEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\nMODEL_ID = \"Qwen/Qwen2.5-0.5B-Instruct\"\nWORKDIR = Path(\"/kaggle/working/on_policy_cl_stress_test\")\nWORKDIR.mkdir(parents=True, exist_ok=True)\n\n# Increase these only after the notebook works end-to-end.\nN_OLD_TRAIN = 384\nN_OLD_TEST = 160\nN_TARGET_TRAIN = 384\nN_TARGET_TEST = 160\nMAX_LENGTH = 128\nMAX_NEW_TOKENS = 4\nROUNDS = 4\nSAMPLES_PER_PROMPT = 4\nLEARNING_RATE = 2e-4\nBATCH_SIZE = 8\nGRAD_ACCUM = 2\n\nprint(\"device:\", DEVICE)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:31:24.199537Z","iopub.execute_input":"2026-07-20T16:31:24.199977Z","iopub.status.idle":"2026-07-20T16:31:47.844292Z","shell.execute_reply.started":"2026-07-20T16:31:24.199942Z","shell.execute_reply":"2026-07-20T16:31:47.843574Z"}},"outputs":[{"name":"stdout","text":"device: cuda\n","output_type":"stream"}],"execution_count":2},{"id":"3ca89726","cell_type":"markdown","source":"\n## Authenticate to the Hugging Face Hub\n\nThe model used below is public, but authenticated downloads avoid anonymous rate limits.\nThis cell deliberately stops with a clear message when `HF_TOKEN` is unavailable.\n","metadata":{}},{"id":"18774fad","cell_type":"code","source":"\n# Secure authentication: Kaggle Secret first, environment variable second.\nfrom huggingface_hub import login, whoami\n\nREQUIRE_HF_TOKEN = True\nHF_TOKEN = None\nauth_source = None\nsecret_error = None\n\ntry:\n    from kaggle_secrets import UserSecretsClient\n    HF_TOKEN = UserSecretsClient().get_secret(\"HF_TOKEN\")\n    if HF_TOKEN:\n        auth_source = \"Kaggle Secret\"\nexcept Exception as exc:\n    secret_error = exc\n\nif not HF_TOKEN:\n    HF_TOKEN = (\n        os.environ.get(\"HF_TOKEN\")\n        or os.environ.get(\"HUGGING_FACE_HUB_TOKEN\")\n    )\n    if HF_TOKEN:\n        auth_source = \"environment variable\"\n\nif not HF_TOKEN and REQUIRE_HF_TOKEN:\n    raise RuntimeError(\n        \"HF_TOKEN was not found. In Kaggle, open Add-ons → Secrets, \"\n        \"add a secret named exactly HF_TOKEN, attach/enable it for this \"\n        \"notebook, confirm Internet is enabled, then restart and run all. \"\n        f\"Kaggle secret lookup detail: {type(secret_error).__name__ if secret_error else 'none'}\"\n    )\n\nif HF_TOKEN:\n    # Make the token available to huggingface_hub and libraries that use it.\n    os.environ[\"HF_TOKEN\"] = HF_TOKEN\n    os.environ[\"HUGGING_FACE_HUB_TOKEN\"] = HF_TOKEN\n    login(token=HF_TOKEN, add_to_git_credential=False)\n\n    account = whoami(token=HF_TOKEN)\n    print(\n        \"Hugging Face authentication succeeded:\",\n        account.get(\"name\", \"<account>\"),\n        f\"via {auth_source}.\",\n    )\n    HF_HUB_KWARGS = {\"token\": HF_TOKEN}\nelse:\n    # Set REQUIRE_HF_TOKEN=False only when anonymous public-model access is intended.\n    print(\"Proceeding anonymously; Hub rate limits may apply.\")\n    HF_HUB_KWARGS = {}\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:32:40.122321Z","iopub.execute_input":"2026-07-20T16:32:40.123005Z","iopub.status.idle":"2026-07-20T16:32:40.576891Z","shell.execute_reply.started":"2026-07-20T16:32:40.122976Z","shell.execute_reply":"2026-07-20T16:32:40.575987Z"}},"outputs":[{"name":"stderr","text":"Note: Environment variable`HF_TOKEN` is set and is the current active token independently from the token you've just configured.\n","output_type":"stream"},{"name":"stdout","text":"Hugging Face authentication succeeded: crystal-cheung via Kaggle Secret.\n","output_type":"stream"}],"execution_count":3},{"id":"4783e05c","cell_type":"markdown","source":"\n## 1. Controlled continual-learning tasks\n\nAll outputs are one of `A`, `B`, `C`, or `D`, making exact verification inexpensive.\n\n- **Old task:** classify an integer by `n mod 4`.\n- **Supported target:** classify `(n + 1) mod 4`. It shares the old task's representation and output vocabulary.\n- **Novel target:** memorize a random ID-to-label mapping. Correct outputs are not inferable from the prompt structure.\n- **Conflict target:** use the same prompt namespace and inputs as the old task, but reverse the labels. No policy can be simultaneously perfect on both tasks without conditioning information, so this is a necessary boundary case rather than a fair “solvable retention” setting.\n","metadata":{}},{"id":"e90b000e","cell_type":"code","source":"\nLABELS = [\"A\", \"B\", \"C\", \"D\"]\n\ndef old_label(n: int) -> str:\n    return LABELS[n % 4]\n\ndef supported_label(n: int) -> str:\n    return LABELS[(n + 1) % 4]\n\ndef conflict_label(n: int) -> str:\n    return LABELS[3 - (n % 4)]\n\nrng = np.random.default_rng(SEED)\nnovel_map = {i: LABELS[int(rng.integers(0, 4))] for i in range(2000)}\n\ndef make_examples(task: str, n_examples: int, offset: int = 0) -> List[Dict[str, str]]:\n    rows = []\n    for j in range(n_examples):\n        n = offset + j\n        if task == \"old\":\n            prompt = f\"Task OLD. Integer: {n}. Return exactly one label: A, B, C, or D.\"\n            answer = old_label(n)\n        elif task == \"supported\":\n            prompt = f\"Task SHIFT. Integer: {n}. Return exactly one label: A, B, C, or D.\"\n            answer = supported_label(n)\n        elif task == \"novel\":\n            idx = n % 2000\n            prompt = f\"Task LOOKUP. Identifier: item_{idx:04d}. Return exactly one label: A, B, C, or D.\"\n            answer = novel_map[idx]\n        elif task == \"conflict\":\n            # Deliberately identical task name and input format to OLD.\n            prompt = f\"Task OLD. Integer: {n}. Return exactly one label: A, B, C, or D.\"\n            answer = conflict_label(n)\n        else:\n            raise ValueError(task)\n        rows.append({\"prompt\": prompt, \"answer\": answer, \"task\": task})\n    return rows\n\nold_train = make_examples(\"old\", N_OLD_TRAIN, 0)\nold_test = make_examples(\"old\", N_OLD_TEST, 1000)\n\ntarget_data = {\n    \"supported\": {\n        \"train\": make_examples(\"supported\", N_TARGET_TRAIN, 0),\n        \"test\": make_examples(\"supported\", N_TARGET_TEST, 1000),\n    },\n    \"novel\": {\n        \"train\": make_examples(\"novel\", N_TARGET_TRAIN, 0),\n        \"test\": make_examples(\"novel\", N_TARGET_TEST, 0),\n    },\n    \"conflict\": {\n        \"train\": make_examples(\"conflict\", N_TARGET_TRAIN, 0),\n        \"test\": make_examples(\"conflict\", N_TARGET_TEST, 1000),\n    },\n}\nold_train[:2], target_data[\"novel\"][\"train\"][:2]\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:32:49.057692Z","iopub.execute_input":"2026-07-20T16:32:49.058455Z","iopub.status.idle":"2026-07-20T16:32:49.078475Z","shell.execute_reply.started":"2026-07-20T16:32:49.058423Z","shell.execute_reply":"2026-07-20T16:32:49.077594Z"}},"outputs":[{"execution_count":4,"output_type":"execute_result","data":{"text/plain":"([{'prompt': 'Task OLD. Integer: 0. Return exactly one label: A, B, C, or D.',\n   'answer': 'A',\n   'task': 'old'},\n  {'prompt': 'Task OLD. Integer: 1. Return exactly one label: A, B, C, or D.',\n   'answer': 'B',\n   'task': 'old'}],\n [{'prompt': 'Task LOOKUP. Identifier: item_0000. Return exactly one label: A, B, C, or D.',\n   'answer': 'A',\n   'task': 'novel'},\n  {'prompt': 'Task LOOKUP. Identifier: item_0001. Return exactly one label: A, B, C, or D.',\n   'answer': 'D',\n   'task': 'novel'}])"},"metadata":{}}],"execution_count":4},{"id":"05f50bfa","cell_type":"code","source":"\ntokenizer = AutoTokenizer.from_pretrained(\n    MODEL_ID,\n    use_fast=True,\n    **HF_HUB_KWARGS,\n)\nif tokenizer.pad_token is None:\n    tokenizer.pad_token = tokenizer.eos_token\ntokenizer.padding_side = \"left\"  # correct padding direction for decoder-only generation\n\ndef format_prompt(prompt: str) -> str:\n    messages = [{\"role\": \"user\", \"content\": prompt}]\n    return tokenizer.apply_chat_template(\n        messages, tokenize=False, add_generation_prompt=True\n    )\n\ndef encode_supervised(row: Dict[str, str]) -> Dict[str, List[int]]:\n    prefix = format_prompt(row[\"prompt\"])\n    full = prefix + row[\"answer\"] + tokenizer.eos_token\n\n    prefix_ids = tokenizer(prefix, add_special_tokens=False)[\"input_ids\"]\n    enc = tokenizer(\n        full,\n        truncation=True,\n        max_length=MAX_LENGTH,\n        add_special_tokens=False,\n    )\n    input_ids = enc[\"input_ids\"]\n    labels = [-100] * min(len(prefix_ids), len(input_ids))\n    labels += input_ids[len(labels):]\n    return {\n        \"input_ids\": input_ids,\n        \"attention_mask\": enc[\"attention_mask\"],\n        \"labels\": labels,\n    }\n\nclass CausalCollator:\n    def __call__(self, features):\n        max_len = max(len(x[\"input_ids\"]) for x in features)\n        input_ids, attention_mask, labels = [], [], []\n        for x in features:\n            pad = max_len - len(x[\"input_ids\"])\n            input_ids.append(x[\"input_ids\"] + [tokenizer.pad_token_id] * pad)\n            attention_mask.append(x[\"attention_mask\"] + [0] * pad)\n            labels.append(x[\"labels\"] + [-100] * pad)\n        return {\n            \"input_ids\": torch.tensor(input_ids, dtype=torch.long),\n            \"attention_mask\": torch.tensor(attention_mask, dtype=torch.long),\n            \"labels\": torch.tensor(labels, dtype=torch.long),\n        }\n\ncollator = CausalCollator()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:32:50.883213Z","iopub.execute_input":"2026-07-20T16:32:50.883809Z","iopub.status.idle":"2026-07-20T16:32:52.793613Z","shell.execute_reply.started":"2026-07-20T16:32:50.88377Z","shell.execute_reply":"2026-07-20T16:32:52.792743Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"config.json:   0%|          | 0.00/659 [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"7a7157e163064fefa1d11cfc3071b4d9"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"tokenizer_config.json:   0%|          | 0.00/7.30k [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"01ed0a209fed4b278264e7ac4369a738"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"vocab.json:   0%|          | 0.00/2.78M [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"230c011871f145139b5f62171f7d2981"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"merges.txt:   0%|          | 0.00/1.67M [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"f0947c43111742a3819c09eb4608f822"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"tokenizer.json:   0%|          | 0.00/7.03M [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"ac6e5f7bd08b441f8314916d6bf00a99"}},"metadata":{}}],"execution_count":5},{"id":"4c29cd95","cell_type":"code","source":"\nLORA_CONFIG = LoraConfig(\n    r=16,\n    lora_alpha=32,\n    lora_dropout=0.05,\n    bias=\"none\",\n    task_type=\"CAUSAL_LM\",\n    target_modules=[\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"up_proj\", \"down_proj\"],\n)\n\ndef load_fresh_lora(adapter_path: str = None):\n    dtype = torch.float16 if torch.cuda.is_available() else torch.float32\n    device_map = {\"\": 0} if torch.cuda.is_available() else None\n    base = AutoModelForCausalLM.from_pretrained(\n        MODEL_ID,\n        torch_dtype=dtype,\n        device_map=device_map,\n        low_cpu_mem_usage=True,\n        **HF_HUB_KWARGS,\n    )\n    base.config.use_cache = False\n    if adapter_path is None:\n        model = get_peft_model(base, LORA_CONFIG)\n    else:\n        model = PeftModel.from_pretrained(base, adapter_path, is_trainable=True)\n    return model\n\ndef train_rows(\n    model,\n    rows: List[Dict[str, str]],\n    output_dir: Path,\n    epochs: float = 1.0,\n    max_steps: int = -1,\n):\n    if len(rows) == 0:\n        return model\n    ds = Dataset.from_list(rows).map(\n        encode_supervised,\n        remove_columns=list(rows[0].keys()),\n    )\n    args = TrainingArguments(\n        output_dir=str(output_dir),\n        per_device_train_batch_size=BATCH_SIZE,\n        gradient_accumulation_steps=GRAD_ACCUM,\n        learning_rate=LEARNING_RATE,\n        num_train_epochs=epochs,\n        max_steps=max_steps,\n        logging_steps=10,\n        save_strategy=\"no\",\n        report_to=\"none\",\n        fp16=torch.cuda.is_available(),\n        optim=\"adamw_torch\",\n        warmup_ratio=0.05,\n        lr_scheduler_type=\"cosine\",\n        seed=SEED,\n    )\n    trainer = Trainer(\n        model=model,\n        args=args,\n        train_dataset=ds,\n        data_collator=collator,\n    )\n    trainer.train()\n    return model\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:32:56.387455Z","iopub.execute_input":"2026-07-20T16:32:56.388221Z","iopub.status.idle":"2026-07-20T16:32:56.397919Z","shell.execute_reply.started":"2026-07-20T16:32:56.388191Z","shell.execute_reply":"2026-07-20T16:32:56.396997Z"}},"outputs":[],"execution_count":6},{"id":"20083e14","cell_type":"code","source":"\nANSWER_RE = re.compile(r\"\\b([ABCD])\\b\")\n\n@torch.no_grad()\ndef generate_answers(\n    model,\n    rows: List[Dict[str, str]],\n    do_sample: bool = False,\n    temperature: float = 0.8,\n    num_return_sequences: int = 1,\n    batch_size: int = 24,\n) -> List[List[str]]:\n    model.eval()\n    outputs_all = []\n    for start in range(0, len(rows), batch_size):\n        batch = rows[start:start + batch_size]\n        prompts = [format_prompt(x[\"prompt\"]) for x in batch]\n        toks = tokenizer(\n            prompts,\n            return_tensors=\"pt\",\n            padding=True,\n            truncation=True,\n            max_length=MAX_LENGTH - MAX_NEW_TOKENS,\n        ).to(model.device)\n        gen = model.generate(\n            **toks,\n            max_new_tokens=MAX_NEW_TOKENS,\n            do_sample=do_sample,\n            temperature=temperature if do_sample else None,\n            top_p=0.95 if do_sample else None,\n            num_return_sequences=num_return_sequences,\n            pad_token_id=tokenizer.pad_token_id,\n            eos_token_id=tokenizer.eos_token_id,\n        )\n        prompt_len = toks[\"input_ids\"].shape[1]\n        decoded = tokenizer.batch_decode(\n            gen[:, prompt_len:], skip_special_tokens=True\n        )\n        for i in range(len(batch)):\n            group = decoded[\n                i * num_return_sequences:(i + 1) * num_return_sequences\n            ]\n            parsed = []\n            for text in group:\n                m = ANSWER_RE.search(text.strip().upper())\n                parsed.append(m.group(1) if m else \"\")\n            outputs_all.append(parsed)\n    return outputs_all\n\n@torch.no_grad()\ndef accuracy(model, rows: List[Dict[str, str]]) -> float:\n    preds = generate_answers(model, rows, do_sample=False)\n    return float(np.mean([p[0] == r[\"answer\"] for p, r in zip(preds, rows)]))\n\n@torch.no_grad()\ndef policy_coverage(\n    model,\n    rows: List[Dict[str, str]],\n    k: int = SAMPLES_PER_PROMPT,\n) -> Tuple[float, float]:\n    samples = generate_answers(\n        model, rows, do_sample=True, num_return_sequences=k\n    )\n    per_prompt = [\n        sum(x == row[\"answer\"] for x in xs) / k\n        for xs, row in zip(samples, rows)\n    ]\n    return float(np.mean(np.array(per_prompt) > 0)), float(np.mean(per_prompt))\n\ndef collect_verified_on_policy(\n    model,\n    rows: List[Dict[str, str]],\n    k: int = SAMPLES_PER_PROMPT,\n) -> List[Dict[str, str]]:\n    samples = generate_answers(\n        model, rows, do_sample=True, num_return_sequences=k\n    )\n    kept = []\n    for row, xs in zip(rows, samples):\n        correct = [x for x in xs if x == row[\"answer\"]]\n        if correct:\n            # Train on a trajectory actually sampled from the current policy.\n            kept.append({**row, \"answer\": correct[0]})\n    return kept\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:33:09.042689Z","iopub.execute_input":"2026-07-20T16:33:09.043087Z","iopub.status.idle":"2026-07-20T16:33:09.06425Z","shell.execute_reply.started":"2026-07-20T16:33:09.043048Z","shell.execute_reply":"2026-07-20T16:33:09.063219Z"}},"outputs":[],"execution_count":8},{"id":"f4eb8647","cell_type":"markdown","source":"\n## 2. Establish an old capability\n\nWe first train one LoRA adapter on the old task. Every target-method run starts from this identical checkpoint.\n","metadata":{}},{"id":"d9b3903b","cell_type":"code","source":"\nOLD_ADAPTER = WORKDIR / \"old_adapter\"\nif OLD_ADAPTER.exists():\n    shutil.rmtree(OLD_ADAPTER)\n\nmodel = load_fresh_lora()\nmodel = train_rows(model, old_train, WORKDIR / \"old_train\", epochs=3.0)\nprint(\"Old-task accuracy after stage 0:\", accuracy(model, old_test))\nmodel.save_pretrained(OLD_ADAPTER)\n\ndel model\ngc.collect()\nif torch.cuda.is_available():\n    torch.cuda.empty_cache()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:33:13.163904Z","iopub.execute_input":"2026-07-20T16:33:13.164675Z","iopub.status.idle":"2026-07-20T16:34:09.064842Z","shell.execute_reply.started":"2026-07-20T16:33:13.164644Z","shell.execute_reply":"2026-07-20T16:34:09.063961Z"}},"outputs":[{"name":"stderr","text":"[transformers] `torch_dtype` is deprecated! Use `dtype` instead!\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"model.safetensors: reconstructing file:   0%|          |  0.00B /  988MB            ","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"4d7b4ccab49d48f492e4ad6c4dfc1e57"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"model.safetensors: downloading bytes:           |  0.00B            ","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"66649280dd3747e8b1e30d3f1f4a0fbe"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/290 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"829fc68dd23940f18673bda491ad5ee3"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"generation_config.json:   0%|          | 0.00/242 [00:00<?, ?B/s]","application/vnd.jupyter.widget