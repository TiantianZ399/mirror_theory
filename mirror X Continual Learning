   mean_success_prob: float\n    train_examples: int\n\ndef evaluate_record(model, scenario, method, round_idx, baseline_old, train_rows_count):\n    target_test = target_data[scenario][\"test\"]\n    cov, success_prob = policy_coverage(\n        model, target_data[scenario][\"train\"][:128]\n    )\n    old_acc = accuracy(model, old_test)\n    target_acc = accuracy(model, target_test)\n    return Record(\n        scenario=scenario,\n        method=method,\n        round=round_idx,\n        target_acc=target_acc,\n        old_acc=old_acc,\n        forgetting=baseline_old - old_acc,\n        prompt_coverage=cov,\n        mean_success_prob=success_prob,\n        train_examples=train_rows_count,\n    )\n\ndef run_method(scenario: str, method: str) -> List[Record]:\n    model = load_fresh_lora(str(OLD_ADAPTER))\n    baseline_old = accuracy(model, old_test)\n    records = [\n        evaluate_record(model, scenario, method, 0, baseline_old, 0)\n    ]\n    expert_rows = target_data[scenario][\"train\"]\n\n    for round_idx in range(1, ROUNDS + 1):\n        cov, _ = policy_coverage(model, expert_rows[:128])\n\n        if method == \"offline_sft\":\n            rows = expert_rows\n        elif method == \"iterative_on_policy\":\n            rows = collect_verified_on_policy(model, expert_rows)\n        elif method == \"mixed\":\n            if cov < 0.30:\n                rows = expert_rows\n            else:\n                rows = collect_verified_on_policy(model, expert_rows)\n        else:\n            raise ValueError(method)\n\n        print(\n            f\"{scenario=} {method=} round={round_idx} \"\n            f\"coverage={cov:.3f} train_n={len(rows)}\"\n        )\n\n        # Empty self-generated set is itself a meaningful failure:\n        # the target is outside current policy support.\n        if rows:\n            model = train_rows(\n                model,\n                rows,\n                WORKDIR / f\"{scenario}_{method}_{round_idx}\",\n                epochs=1.0,\n            )\n\n        records.append(\n            evaluate_record(\n                model, scenario, method, round_idx, baseline_old, len(rows)\n            )\n        )\n\n    del model\n    gc.collect()\n    if torch.cuda.is_available():\n        torch.cuda.empty_cache()\n    return records\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:35:07.633098Z","iopub.execute_input":"2026-07-20T16:35:07.633566Z","iopub.status.idle":"2026-07-20T16:35:07.643994Z","shell.execute_reply.started":"2026-07-20T16:35:07.633532Z","shell.execute_reply":"2026-07-20T16:35:07.643091Z"}},"outputs":[],"execution_count":10},{"id":"5dfab172","cell_type":"code","source":"\nall_records = []\nfor scenario in [\"supported\", \"novel\", \"conflict\"]:\n    for method in [\"offline_sft\", \"iterative_on_policy\", \"mixed\"]:\n        all_records.extend(run_method(scenario, method))\n\nresults = pd.DataFrame([asdict(r) for r in all_records])\nresults.to_csv(WORKDIR / \"results.csv\", index=False)\nresults\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-20T16:35:14.365473Z","iopub.execute_input":"2026-07-20T16:35:14.365885Z","iopub.status.idle":"2026-07-20T17:01:51.18294Z","shell.execute_reply.started":"2026-07-20T16:35:14.365855Z","shell.execute_reply":"2026-07-20T17:01:51.182209Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/290 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"901cc47a702d48458896af642ba0ae86"}},"metadata":{}},{"name":"stdout","text":"scenario='supported' method='offline_sft' round=1 coverage=0.672 train_n=384\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Map:   0%|          | 0/384 [00:00<?, ? examples/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"d8321df397d741629713b77bfce8c8b2"}},"metadata":{}},{"name":"stderr"